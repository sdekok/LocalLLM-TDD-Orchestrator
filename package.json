{
  "name": "tdd-agentic-workflow",
  "version": "2.0.0",
  "description": "Agentic TDD workflow orchestrator for Pi, powered by local LLMs via llama.cpp",
  "main": "dist/interfaces/mcp/index.js",
  "type": "module",
  "pi": {
    "extensions": [
      "./dist/interfaces/pi"
    ]
  },
  "scripts": {
    "build": "tsc && npm run bundle && rm -rf dist/interfaces/pi/tools && mkdir -p dist/interfaces/pi/tools && cp -r src/analysis/tools/* dist/interfaces/pi/tools/",
    "build:csharp": "dotnet build src/analysis/tools/CsharpAstAnalyzer/CsharpAstAnalyzer.csproj -c Release",
    "build:all": "npm run build:csharp && npm run build",
    "bundle": "esbuild dist/interfaces/pi/index.js --bundle --platform=node --format=esm --outfile=dist/interfaces/pi/index.bundle.js --external:tree-sitter --external:tree-sitter-cpp && mv dist/interfaces/pi/index.bundle.js dist/interfaces/pi/index.js",
    "deploylocal": "npm run build && rm -rf ~/.pi/extensions/tdd-workflow && ln -sf $(pwd) ~/.pi/extensions/tdd-workflow",
    "start": "node dist/interfaces/mcp/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "keywords": [
    "tdd",
    "mcp",
    "pi-package",
    "llm",
    "pi-agent",
    "llama-cpp"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "@mariozechner/pi-coding-agent": "^0.65.0",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "@mozilla/readability": "^0.6.0",
    "@sinclair/typebox": "^0.34.28",
    "jsdom": "^29.0.2",
    "json5": "^2.2.3",
    "openai": "^6.33.0",
    "pi-lens": "^3.8.21",
    "tree-sitter": "^0.21.1",
    "tree-sitter-cpp": "^0.23.4",
    "ts-morph": "^27.0.2",
    "turndown": "^7.2.4",
    "uuid": "^13.0.0",
    "web-tree-sitter": "^0.26.8",
    "youtube-transcript": "^1.3.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/jsdom": "^28.0.1",
    "@types/node": "^25.5.2",
    "@types/turndown": "^5.0.6",
    "@types/uuid": "^10.0.0",
    "@vitest/coverage-v8": "^4.1.2",
    "esbuild": "^0.27.7",
    "typescript": "^6.0.2",
    "vitest": "^4.1.2"
  }
}
